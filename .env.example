PROJECT_NAME=University Knowledge Base RAG Assistant
QDRANT_COLLECTION_NAME=university_knowledge_base
QDRANT_LOCAL_PATH=.qdrant
QDRANT_URL=
QDRANT_API_KEY=
CORPUS_MANIFEST_PATH=data/corpus_manifest.csv

# Default local dev mode works without paid APIs.
EMBEDDING_PROVIDER=hash
GENERATION_PROVIDER=extractive

# Recommended interview/demo mode.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_API_BASE=

# OpenRouter mode.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=University Knowledge Base Assistant

CHUNK_SIZE=700
CHUNK_OVERLAP=80
RETRIEVAL_K=5
RETRIEVAL_STRATEGY=hybrid
DENSE_RETRIEVAL_K=10
SPARSE_RETRIEVAL_K=10
HYBRID_CANDIDATE_K=15
RRF_K=60
MAX_CHUNKS_PER_DOC=2
SIMILARITY_SCORE_THRESHOLD=
